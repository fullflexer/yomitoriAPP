DATABASE_URL=postgresql://<db-user>:<db-password>@<db-host>:5432/<db-name>
REDIS_URL=redis://<redis-host>:6379
S3_ENDPOINT=http://<s3-host>:9000
S3_BUCKET=<your-bucket-name>
S3_ACCESS_KEY=<your-s3-access-key>
S3_SECRET_KEY=<your-s3-secret-key>
ANTHROPIC_API_KEY=<your-anthropic-api-key>
OCR_PROVIDER=glm-ocr
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=glm-ocr
OCR_COST_PER_1K_TOKENS_USD=0
OCR_CONCURRENCY=1
BASIC_AUTH_USER=<your-basic-auth-user>
BASIC_AUTH_PASS=<your-basic-auth-password>
