    "@prisma/client": "6.19.2",
    "@types/pg": "^8.20.0",
    "bullmq": "^5.47.0",
    "clsx": "^2.1.1",
    "elkjs": "^0.10.0",
    "ioredis": "^5.4.2",
    "next": "^16.2.1",
    "pg": "^8.20.0",
    "puppeteer-core": "^24.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "reactflow": "^11.11.4",
    "sharp": "^0.34.5",
